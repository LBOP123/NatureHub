<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.naturalhub.system.mapper.CommunityCommentMapper">
    
    <resultMap type="CommunityComment" id="CommunityCommentResult">
        <result property="commentId"    column="comment_id"    />
        <result property="topicId"    column="topic_id"    />
        <result property="userId"    column="user_id"    />
        <result property="userName"    column="user_name"    />
        <result property="parentId"    column="parent_id"    />
        <result property="replyToId"    column="reply_to_id"    />
        <result property="replyToName"    column="reply_to_name"    />
        <result property="content"    column="content"    />
        <result property="likeCount"    column="like_count"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectCommunityCommentVo">
        select comment_id, topic_id, user_id, user_name, parent_id, reply_to_id, reply_to_name, 
               content, like_count, status, create_by, create_time, update_by, update_time 
        from nh_community_comment
    </sql>

    <select id="selectCommunityCommentList" parameterType="CommunityComment" resultMap="CommunityCommentResult">
        <include refid="selectCommunityCommentVo"/>
        <where>  
            <if test="topicId != null "> and topic_id = #{topicId}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="parentId != null "> and parent_id = #{parentId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by create_time asc
    </select>
    
    <select id="selectCommunityCommentByCommentId" parameterType="Long" resultMap="CommunityCommentResult">
        <include refid="selectCommunityCommentVo"/>
        where comment_id = #{commentId}
    </select>
        
    <insert id="insertCommunityComment" parameterType="CommunityComment" useGeneratedKeys="true" keyProperty="commentId">
        insert into nh_community_comment
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="topicId != null">topic_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="userName != null">user_name,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="replyToId != null">reply_to_id,</if>
            <if test="replyToName != null">reply_to_name,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="likeCount != null">like_count,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="topicId != null">#{topicId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="userName != null">#{userName},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="replyToId != null">#{replyToId},</if>
            <if test="replyToName != null">#{replyToName},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="likeCount != null">#{likeCount},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateCommunityComment" parameterType="CommunityComment">
        update nh_community_comment
        <trim prefix="SET" suffixOverrides=",">
            <if test="topicId != null">topic_id = #{topicId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="userName != null">user_name = #{userName},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="replyToId != null">reply_to_id = #{replyToId},</if>
            <if test="replyToName != null">reply_to_name = #{replyToName},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where comment_id = #{commentId}
    </update>

    <delete id="deleteCommunityCommentByCommentId" parameterType="Long">
        update nh_community_comment set status = '1' where comment_id = #{commentId}
    </delete>

    <delete id="deleteCommunityCommentByCommentIds" parameterType="String">
        update nh_community_comment set status = '1' where comment_id in 
        <foreach item="commentId" collection="array" open="(" separator="," close=")">
            #{commentId}
        </foreach>
    </delete>

    <select id="countCommentsByTopicId" parameterType="Long" resultType="int">
        select count(*) from nh_community_comment where topic_id = #{topicId} and status = '0'
    </select>

    <select id="checkUserLikeComment" resultType="int">
        select count(*) from nh_community_like 
        where user_id = #{userId} and target_type = 'comment' and target_id = #{commentId}
    </select>
</mapper>
