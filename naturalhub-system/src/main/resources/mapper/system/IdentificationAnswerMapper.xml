<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.naturalhub.system.mapper.IdentificationAnswerMapper">
    
    <resultMap type="IdentificationAnswer" id="IdentificationAnswerResult">
        <result property="answerId"    column="answer_id"    />
        <result property="identificationId"    column="identification_id"    />
        <result property="userId"    column="user_id"    />
        <result property="userName"    column="user_name"    />
        <result property="content"    column="content"    />
        <result property="speciesName"    column="species_name"    />
        <result property="confidence"    column="confidence"    />
        <result property="reference"    column="reference"    />
        <result property="images"    column="images"    />
        <result property="isBest"    column="is_best"    />
        <result property="likeCount"    column="like_count"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectIdentificationAnswerVo">
        select ia.answer_id, ia.identification_id, ia.user_id, ia.user_name, ia.content, 
               ia.species_name, ia.confidence, ia.reference, ia.images, ia.is_best, ia.like_count,
               ia.del_flag, ia.create_time, ia.update_time
        from nh_identification_answer ia
    </sql>

    <select id="selectIdentificationAnswerList" parameterType="IdentificationAnswer" resultMap="IdentificationAnswerResult">
        <include refid="selectIdentificationAnswerVo"/>
        <where>  
            ia.del_flag = '0'
            <if test="identificationId != null "> and ia.identification_id = #{identificationId}</if>
            <if test="userId != null "> and ia.user_id = #{userId}</if>
            <if test="speciesName != null  and speciesName != ''"> and ia.species_name like concat('%', #{speciesName}, '%')</if>
            <if test="confidence != null  and confidence != ''"> and ia.confidence = #{confidence}</if>
            <if test="isBest != null"> and ia.is_best = #{isBest}</if>
        </where>
        order by ia.is_best desc, ia.like_count desc, ia.create_time asc
    </select>
    
    <select id="selectIdentificationAnswerByAnswerId" parameterType="Long" resultMap="IdentificationAnswerResult">
        <include refid="selectIdentificationAnswerVo"/>
        where ia.answer_id = #{answerId} and ia.del_flag = '0'
    </select>

    <select id="selectAnswersByIdentificationId" parameterType="Long" resultMap="IdentificationAnswerResult">
        <include refid="selectIdentificationAnswerVo"/>
        where ia.identification_id = #{identificationId} and ia.del_flag = '0'
        order by ia.is_best desc, ia.like_count desc, ia.create_time asc
    </select>
        
    <insert id="insertIdentificationAnswer" parameterType="IdentificationAnswer" useGeneratedKeys="true" keyProperty="answerId">
        insert into nh_identification_answer
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="identificationId != null">identification_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="userName != null">user_name,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="speciesName != null">species_name,</if>
            <if test="confidence != null">confidence,</if>
            <if test="reference != null">reference,</if>
            <if test="images != null">images,</if>
            <if test="isBest != null">is_best,</if>
            <if test="likeCount != null">like_count,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="identificationId != null">#{identificationId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="userName != null">#{userName},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="speciesName != null">#{speciesName},</if>
            <if test="confidence != null">#{confidence},</if>
            <if test="reference != null">#{reference},</if>
            <if test="images != null">#{images},</if>
            <if test="isBest != null">#{isBest},</if>
            <if test="likeCount != null">#{likeCount},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateIdentificationAnswer" parameterType="IdentificationAnswer">
        update nh_identification_answer
        <trim prefix="SET" suffixOverrides=",">
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="speciesName != null">species_name = #{speciesName},</if>
            <if test="confidence != null">confidence = #{confidence},</if>
            <if test="reference != null">reference = #{reference},</if>
            <if test="images != null">images = #{images},</if>
            <if test="isBest != null">is_best = #{isBest},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where answer_id = #{answerId}
    </update>

    <delete id="deleteIdentificationAnswerByAnswerId" parameterType="Long">
        update nh_identification_answer set del_flag = '2' where answer_id = #{answerId}
    </delete>

    <delete id="deleteIdentificationAnswerByAnswerIds" parameterType="String">
        update nh_identification_answer set del_flag = '2' where answer_id in 
        <foreach item="answerId" collection="array" open="(" separator="," close=")">
            #{answerId}
        </foreach>
    </delete>

    <update id="setBestAnswer">
        update nh_identification_answer set is_best = 
        case when answer_id = #{answerId} then 1 else 0 end
        where identification_id = #{identificationId}
    </update>

    <update id="cancelBestAnswer" parameterType="Long">
        update nh_identification_answer set is_best = 0 where identification_id = #{identificationId}
    </update>

    <update id="incrementLikeCount" parameterType="Long">
        update nh_identification_answer set like_count = like_count + 1 where answer_id = #{answerId}
    </update>

</mapper>
