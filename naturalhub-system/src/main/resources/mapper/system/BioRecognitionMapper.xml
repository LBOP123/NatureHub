<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.naturalhub.system.mapper.BioRecognitionMapper">

    <resultMap id="BioRecognitionResult" type="com.naturalhub.system.domain.BioRecognition">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="imageUrl" column="image_url"/>
        <result property="recognitionResult" column="recognition_result"/>
        <result property="recognitionType" column="recognition_type"/>
        <result property="confidence" column="confidence"/>
        <result property="status" column="status"/>
        <result property="baikeInfo" column="baike_info"/>
        <result property="allResults" column="all_results"/>
        <!-- 【新增】is_shared / shared_topic_id 字段映射 -->
        <result property="isShared" column="is_shared"/>
        <result property="sharedTopicId" column="shared_topic_id"/>
        <result property="remark" column="remark"/>
        <result property="ipAddress" column="ip_address"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectBioRecognitionVo">
        select id, user_id, username, image_url, recognition_result, recognition_type,
               confidence, status, baike_info, all_results, is_shared, shared_topic_id,
               remark, ip_address, create_time
        from bio_recognition
    </sql>

    <insert id="insertBioRecognition" parameterType="com.naturalhub.system.domain.BioRecognition" useGeneratedKeys="true" keyProperty="id">
        insert into bio_recognition
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="username != null">username,</if>
            <if test="imageUrl != null">image_url,</if>
            <if test="recognitionResult != null">recognition_result,</if>
            <if test="recognitionType != null">recognition_type,</if>
            <if test="confidence != null">confidence,</if>
            <if test="status != null">status,</if>
            <if test="baikeInfo != null">baike_info,</if>
            <if test="allResults != null">all_results,</if>
            <if test="isShared != null">is_shared,</if>
            <if test="sharedTopicId != null">shared_topic_id,</if>
            <if test="remark != null">remark,</if>
            <if test="ipAddress != null">ip_address,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="username != null">#{username},</if>
            <if test="imageUrl != null">#{imageUrl},</if>
            <if test="recognitionResult != null">#{recognitionResult},</if>
            <if test="recognitionType != null">#{recognitionType},</if>
            <if test="confidence != null">#{confidence},</if>
            <if test="status != null">#{status},</if>
            <if test="baikeInfo != null">#{baikeInfo},</if>
            <if test="allResults != null">#{allResults},</if>
            <if test="isShared != null">#{isShared},</if>
            <if test="sharedTopicId != null">#{sharedTopicId},</if>
            <if test="remark != null">#{remark},</if>
            <if test="ipAddress != null">#{ipAddress},</if>
            now()
        </trim>
    </insert>

    <select id="selectBioRecognitionList" resultMap="BioRecognitionResult">
        <include refid="selectBioRecognitionVo"/>
        <where>
            <if test="userId != null">and user_id = #{userId}</if>
            <if test="username != null and username != ''">and username like concat('%', #{username}, '%')</if>
            <if test="recognitionResult != null and recognitionResult != ''">and recognition_result like concat('%', #{recognitionResult}, '%')</if>
            <!-- 【改造点】recognitionType / status 均为数字类型，直接等值匹配 -->
            <if test="recognitionType != null">and recognition_type = #{recognitionType}</if>
            <if test="status != null">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectBioRecognitionById" resultMap="BioRecognitionResult">
        <include refid="selectBioRecognitionVo"/>
        where id = #{id}
    </select>

    <delete id="deleteBioRecognitionById">
        delete from bio_recognition where id = #{id}
    </delete>

    <delete id="deleteBioRecognitionByIds">
        delete from bio_recognition where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="countTotal" resultType="int">
        select count(*) from bio_recognition
    </select>

    <select id="countToday" resultType="int">
        select count(*) from bio_recognition
        where DATE(create_time) = CURDATE()
    </select>

    <!-- 【改造点】status = 'success' -> status = 1 -->
    <select id="selectSuccessRate" resultType="map">
        select
            count(*) as total,
            sum(case when status = 1 then 1 else 0 end) as success_count,
            round(sum(case when status = 1 then 1 else 0 end) * 100.0 / count(*), 2) as success_rate
        from bio_recognition
    </select>

    <select id="selectTopSpecies" resultType="string">
        select recognition_result
        from bio_recognition
        where recognition_result is not null and recognition_result != ''
        group by recognition_result
        order by count(*) desc
        limit 1
    </select>

    <select id="selectTrendData" resultType="map">
        select
            DATE_FORMAT(create_time, '%Y-%m-%d') as date,
            count(*) as count
        from bio_recognition
        where create_time >= DATE_SUB(CURDATE(), INTERVAL #{days} DAY)
        group by DATE_FORMAT(create_time, '%Y-%m-%d')
        order by date
    </select>

    <select id="selectSpeciesRank" resultType="map">
        select
            recognition_result as species,
            count(*) as count
        from bio_recognition
        where recognition_result is not null and recognition_result != ''
        group by recognition_result
        order by count desc
        limit #{limit}
    </select>

</mapper>
