<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.naturalhub.system.mapper.CommunityReportMapper">
    
    <resultMap type="CommunityReport" id="CommunityReportResult">
        <result property="reportId"    column="report_id"    />
        <result property="reportType"    column="report_type"    />
        <result property="targetId"    column="target_id"    />
        <result property="targetTitle"    column="target_title"    />
        <result property="targetUserId"    column="target_user_id"    />
        <result property="targetUserName"    column="target_user_name"    />
        <result property="reporterId"    column="reporter_id"    />
        <result property="reporterName"    column="reporter_name"    />
        <result property="reason"    column="reason"    />
        <result property="description"    column="description"    />
        <result property="status"    column="status"    />
        <result property="handleResult"    column="handle_result"    />
        <result property="handleRemark"    column="handle_remark"    />
        <result property="handleTime"    column="handle_time"    />
        <result property="handleBy"    column="handle_by"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectCommunityReportVo">
        select report_id, report_type, target_id, target_title, target_user_id, target_user_name,
               reporter_id, reporter_name, reason, description, status, handle_result, handle_remark,
               handle_time, handle_by, create_by, create_time, update_by, update_time
        from nh_community_report
    </sql>

    <select id="selectCommunityReportList" parameterType="CommunityReport" resultMap="CommunityReportResult">
        <include refid="selectCommunityReportVo"/>
        <where>  
            <if test="reportType != null  and reportType != ''"> and report_type = #{reportType}</if>
            <if test="targetId != null "> and target_id = #{targetId}</if>
            <if test="targetUserName != null  and targetUserName != ''"> and target_user_name like concat('%', #{targetUserName}, '%')</if>
            <if test="reporterName != null  and reporterName != ''"> and reporter_name like concat('%', #{reporterName}, '%')</if>
            <if test="reason != null  and reason != ''"> and reason = #{reason}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectCommunityReportByReportId" parameterType="Long" resultMap="CommunityReportResult">
        <include refid="selectCommunityReportVo"/>
        where report_id = #{reportId}
    </select>
        
    <insert id="insertCommunityReport" parameterType="CommunityReport" useGeneratedKeys="true" keyProperty="reportId">
        insert into nh_community_report
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="reportType != null and reportType != ''">report_type,</if>
            <if test="targetId != null">target_id,</if>
            <if test="targetTitle != null">target_title,</if>
            <if test="targetUserId != null">target_user_id,</if>
            <if test="targetUserName != null">target_user_name,</if>
            <if test="reporterId != null">reporter_id,</if>
            <if test="reporterName != null">reporter_name,</if>
            <if test="reason != null and reason != ''">reason,</if>
            <if test="description != null">description,</if>
            <if test="status != null">status,</if>
            <if test="handleResult != null">handle_result,</if>
            <if test="handleRemark != null">handle_remark,</if>
            <if test="handleTime != null">handle_time,</if>
            <if test="handleBy != null">handle_by,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="reportType != null and reportType != ''">#{reportType},</if>
            <if test="targetId != null">#{targetId},</if>
            <if test="targetTitle != null">#{targetTitle},</if>
            <if test="targetUserId != null">#{targetUserId},</if>
            <if test="targetUserName != null">#{targetUserName},</if>
            <if test="reporterId != null">#{reporterId},</if>
            <if test="reporterName != null">#{reporterName},</if>
            <if test="reason != null and reason != ''">#{reason},</if>
            <if test="description != null">#{description},</if>
            <if test="status != null">#{status},</if>
            <if test="handleResult != null">#{handleResult},</if>
            <if test="handleRemark != null">#{handleRemark},</if>
            <if test="handleTime != null">#{handleTime},</if>
            <if test="handleBy != null">#{handleBy},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateCommunityReport" parameterType="CommunityReport">
        update nh_community_report
        <trim prefix="SET" suffixOverrides=",">
            <if test="reportType != null and reportType != ''">report_type = #{reportType},</if>
            <if test="targetId != null">target_id = #{targetId},</if>
            <if test="targetTitle != null">target_title = #{targetTitle},</if>
            <if test="targetUserId != null">target_user_id = #{targetUserId},</if>
            <if test="targetUserName != null">target_user_name = #{targetUserName},</if>
            <if test="reporterId != null">reporter_id = #{reporterId},</if>
            <if test="reporterName != null">reporter_name = #{reporterName},</if>
            <if test="reason != null and reason != ''">reason = #{reason},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            <if test="handleResult != null">handle_result = #{handleResult},</if>
            <if test="handleRemark != null">handle_remark = #{handleRemark},</if>
            <if test="handleTime != null">handle_time = #{handleTime},</if>
            <if test="handleBy != null">handle_by = #{handleBy},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where report_id = #{reportId}
    </update>

    <delete id="deleteCommunityReportByReportId" parameterType="Long">
        delete from nh_community_report where report_id = #{reportId}
    </delete>

    <delete id="deleteCommunityReportByReportIds" parameterType="String">
        delete from nh_community_report where report_id in 
        <foreach item="reportId" collection="array" open="(" separator="," close=")">
            #{reportId}
        </foreach>
    </delete>
</mapper>
